{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", {"vars": "local", "args": "none"}],
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "curly": "error",
    "no-eval": "error"
  }
}
